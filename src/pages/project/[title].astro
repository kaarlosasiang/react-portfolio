---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  getProjectBySlug,
  getRelatedProjects,
  projectsData,
} from '@/lib/projects-data';
import { RelatedProjects } from '@/components/common/related-projects';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Separator } from '@/components/ui/separator';
import { ArrowLeft, Github, ExternalLink } from 'lucide-react';

export async function getStaticPaths() {
  return projectsData.map((project) => ({
    params: { title: project.slug },
  }));
}

const { title } = Astro.params;
const project = getProjectBySlug(title);

if (!project) {
  return Astro.redirect('/404');
}

const relatedProjects = getRelatedProjects(project.id);
---

<BaseLayout title={`${project.title} - Kaarlo Sasiang`} description={project.description}>
  <div class="min-h-screen bg-background">

    {/* Unified sticky header */}
    <div class="bg-background/80 backdrop-blur-sm border-b sticky top-0 z-50">
      <div class="max-w-3xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/">
          <Button client:load variant="ghost" size="sm" className="gap-2 -ml-2">
            <ArrowLeft size={16} />
            Back
          </Button>
        </a>
        {project.inProgress && (
          <Badge client:load variant="outline" className="text-xs">In Progress</Badge>
        )}
      </div>
    </div>

    <article class="max-w-3xl mx-auto px-4">

      {/* Hero */}
      <div class="mb-10 pt-8">
        <div class="flex flex-wrap gap-2 mb-5">
          {project.tags.map((tag) => (
            <Badge client:load key={tag} variant="outline">{tag}</Badge>
          ))}
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-tight mb-4">
          {project.title}
        </h1>

        <p class="text-lg text-muted-foreground leading-relaxed mb-6 max-w-2xl">
          {project.description}
        </p>

        <div class="flex flex-wrap gap-3 mb-8">
          {project.demoUrl && (
            <a href={project.demoUrl} target="_blank" rel="noopener noreferrer">
              <Button client:load className="gap-2">
                <ExternalLink size={16} />
                View Demo
              </Button>
            </a>
          )}
          {project.githubUrl && (
            <a href={project.githubUrl} target="_blank" rel="noopener noreferrer">
              <Button client:load variant="outline" className="gap-2">
                <Github size={16} />
                View Code
              </Button>
            </a>
          )}
        </div>

        {project.image && (
          <div class="w-full aspect-video rounded-lg overflow-hidden bg-muted border border-border">
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-cover"
            />
          </div>
        )}
      </div>

<Separator client:load className="mb-10" />

      {/* Narrative sections */}
      <div class="space-y-10 mb-12">
        <section id="overview">
          <div class="flex items-baseline gap-3 mb-4">
            <span class="text-xs font-mono text-muted-foreground tabular-nums select-none">01</span>
            <h2 class="text-xl font-semibold tracking-tight">Overview</h2>
          </div>
          <p class="text-base leading-relaxed text-muted-foreground pl-7">
            {project.overview}
          </p>
        </section>

        <section id="challenge">
          <div class="flex items-baseline gap-3 mb-4">
            <span class="text-xs font-mono text-muted-foreground tabular-nums select-none">02</span>
            <h2 class="text-xl font-semibold tracking-tight">The Challenge</h2>
          </div>
          <p class="text-base leading-relaxed text-muted-foreground pl-7">
            {project.challenge}
          </p>
        </section>

        <section id="solution">
          <div class="flex items-baseline gap-3 mb-4">
            <span class="text-xs font-mono text-muted-foreground tabular-nums select-none">03</span>
            <h2 class="text-xl font-semibold tracking-tight">The Solution</h2>
          </div>
          <p class="text-base leading-relaxed text-muted-foreground pl-7">
            {project.solution}
          </p>
        </section>
      </div>

      {/* Key Features */}
      <section class="mb-12" id="features">
        <div class="flex items-baseline gap-3 mb-5">
          <span class="text-xs font-mono text-muted-foreground tabular-nums select-none">04</span>
          <h2 class="text-xl font-semibold tracking-tight">Key Features</h2>
        </div>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 pl-7">
          {project.features.map((feature, idx) => (
            <li class="flex items-start gap-3">
              <span class="shrink-0 mt-[0.2rem] size-5 rounded-full border border-border flex items-center justify-center">
                <span class="text-[10px] font-mono text-muted-foreground tabular-nums leading-none">
                  {String(idx + 1).padStart(2, '0')}
                </span>
              </span>
              <span class="text-sm text-muted-foreground leading-relaxed">{feature}</span>
            </li>
          ))}
        </ul>
      </section>

      {/* Technologies */}
      <section class="mb-12" id="technologies">
        <div class="flex items-baseline gap-3 mb-5">
          <span class="text-xs font-mono text-muted-foreground tabular-nums select-none">05</span>
          <h2 class="text-xl font-semibold tracking-tight">Technologies</h2>
        </div>
        <div class="pl-7 flex flex-wrap gap-2">
          {project.technologies.map((tech) => (
            <span class="inline-flex items-center rounded-md border border-border bg-muted/50 px-2.5 py-1 text-xs font-mono text-foreground">
              {tech}
            </span>
          ))}
        </div>
      </section>

      {/* More Projects */}
      <RelatedProjects client:visible projects={relatedProjects} />

      <Separator client:load className="mb-8" />

      {/* Footer nav */}
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 mb-16">
        <a href="/">
          <Button client:load variant="ghost" size="sm" className="gap-2 -ml-2">
            <ArrowLeft size={16} />
            Back to Portfolio
          </Button>
        </a>

        {(project.demoUrl || project.githubUrl) && (
          <div class="flex gap-2">
            {project.demoUrl && (
              <a href={project.demoUrl} target="_blank" rel="noopener noreferrer">
                <Button client:load size="sm" variant="outline" className="gap-2">
                  <ExternalLink size={14} />
                  Demo
                </Button>
              </a>
            )}
            {project.githubUrl && (
              <a href={project.githubUrl} target="_blank" rel="noopener noreferrer">
                <Button client:load size="sm" variant="ghost" className="gap-2">
                  <Github size={14} />
                  Code
                </Button>
              </a>
            )}
          </div>
        )}
      </div>

    </article>
  </div>
</BaseLayout>
